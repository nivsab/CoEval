# LibreOffice lock files
.~lock.*#

# Python build / cache artefacts
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Experiment runtime outputs (large data; not source)
eval_runs/

# IDE / tool config
.claude/
.idea/
.vscode/

# Provider key files (contain API keys — never commit)
keys.yaml
*.keys.yaml
.coeval/

# Misc temp files
experiments/full_run.log
experiments/non_ascii.txt
*.log

# Paper review files (local only - not for version control)
Docs/paperv2/reviews/
Docs/paperv2/drafts/*.docx
Runs/**/plotly.min.js
